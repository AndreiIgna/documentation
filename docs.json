{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Domo",
  "colors": {
    "primary": "#346cdb",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Search & monitor domains",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Organize your domains",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Domains API",
            "pages": [
              "api-reference/endpoint/domain-lookup",
              "api-reference/endpoint/domain-whois",
              "api-reference/endpoint/domain-rdap",
              "api-reference/endpoint/domain-dns-records",
              "api-reference/endpoint/domain-history",
              "api-reference/endpoint/domain-website-info"
            ]
          },
          {
            "group": "TLDs API",
            "pages": [
              "api-reference/endpoint/tlds",
              "api-reference/endpoint/tld-detail"
            ]
          }
        ]
      }
    ]
  },
  "logo": "/logo/domo-logo.svg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://dmns.app/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dmns.app"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "api": {
    "mdx": {
      "server": "https://domains-api.com/",
      "auth": {
        "method": "bearer"
      }
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/DomainsApp",
      "github": "https://github.com/LayeredStudio"
    }
  },
  "appearance": {
    "default": "system"
  }
}
